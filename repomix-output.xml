        height: 42px;
        border: 1px solid var(--line);
        border-radius: 8px;
        color: var(--ink);
        background: rgba(7, 15, 18, 0.76);
        cursor: pointer;
      }

      .menu-toggle {
        position: fixed;
        top: 18px;
        left: 18px;
        z-index: 12;
        backdrop-filter: blur(14px);
      }

      .menu-toggle svg,
      .icon-button svg {
        width: 20px;
        height: 20px;
      }

      details.panel {
        padding: 0;
      }

      details.panel > summary {
        display: flex;
        align-items: center;
        justify-content: space-between;
        min-height: 52px;
        padding: 0 16px;
        cursor: pointer;
        font-weight: 800;
        list-style: none;
      }

      details.panel > summary::-webkit-details-marker {
        display: none;
      }

      details.panel > summary::after {
        content: "+";
        color: var(--muted);
        font-size: 1.2rem;
      }

      details.panel[open] > summary::after {
        content: "-";
      }

      .panel-body {
        padding: 0 16px 16px;
      }

      .stage {
        position: relative;
        min-height: 100vh;
        overflow: hidden;
      }

      #visualizer {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        touch-action: none;
      }

      .stage-ui {
        position: relative;
        z-index: 2;
        display: grid;
        align-content: end;
        min-height: 100vh;
        padding: clamp(18px, 4vw, 46px);
        padding-bottom: calc(clamp(34px, 7vh, 88px) + env(safe-area-inset-bottom, 0px));
        pointer-events: none;
      }

      .hero-copy {
        width: min(780px, 100%);
      }

      .eyebrow {
        color: var(--aqua);
        font-size: 0.78rem;
        font-weight: 800;
        letter-spacing: 0;
        text-transform: uppercase;
      }

      .hero-copy h2 {
        margin-top: 10px;
        font-size: clamp(2.6rem, 8vw, 7rem);
        line-height: 0.92;
        letter-spacing: 0;
      }

      .hero-copy p {
        width: min(650px, 100%);
        margin-top: 18px;
        color: var(--muted);
        font-size: clamp(1rem, 2vw, 1.18rem);
      }

      .readout {
        display: none;
      }

      .player-bar {
        pointer-events: auto;
        display: grid;
        grid-template-columns: auto minmax(0, 1fr);
        gap: 14px;
        align-items: center;
        width: min(680px, calc(100vw - 36px));
        margin: 0 auto;
        margin-bottom: env(safe-area-inset-bottom, 0px);
        padding: 12px;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: rgba(7, 15, 18, 0.78);
        backdrop-filter: blur(18px);
      }

      .play-toggle {
        width: 54px;
        min-height: 54px;
        padding: 0;
        border-radius: 8px;
        font-size: 1.12rem;
      }

      .track-now {
        min-width: 0;
      }

      .track-now strong,
      .track-now span {
        display: block;
      }

      .track-now strong {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      .track-now span {
        color: var(--muted);
        font-size: 0.82rem;
      }

      .metric,
      .panel,
      .track {
        border: 1px solid var(--line);
        border-radius: 8px;
        background: var(--panel);
      }

      .metric {
        padding: 12px;
        min-height: 72px;
      }

      .metric span {
        display: block;
        color: var(--muted);
        font-size: 0.75rem;
        text-transform: uppercase;
      }

      .metric strong {
        display: block;
        margin-top: 4px;
        font-size: 1.1rem;
      }

      .panel {
        padding: 16px;
        margin-bottom: 16px;
      }

      .panel h3 {
        font-size: 1rem;
      }

      .panel p {
        margin-top: 8px;
        color: var(--muted);
        font-size: 0.92rem;
      }

      .track-list {
        display: grid;
        gap: 10px;
        margin-top: 12px;
      }

      .track {
        width: 100%;
        padding: 12px;
        color: var(--ink);
        text-align: left;
        cursor: pointer;
      }

      .track[aria-selected="true"] {
        border-color: rgba(102, 216, 203, 0.7);
        background: rgba(102, 216, 203, 0.12);
      }

      .track strong,
      .track span {
        display: block;
      }

      .track span {
        margin-top: 3px;
        color: var(--muted);
        font-size: 0.84rem;
      }

      .controls {
        display: grid;
        gap: 10px;
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 42px;
        padding: 9px 13px;
        border: 1px solid var(--line);
        border-radius: 6px;
        color: var(--ink);
        background: rgba(255, 255, 255, 0.08);
        text-decoration: none;
        font-weight: 750;
        cursor: pointer;
      }

      .button.primary {
        border-color: rgba(102, 216, 203, 0.5);
        background: rgba(102, 216, 203, 0.16);
      }

      .button:disabled {
        color: rgba(242, 251, 248, 0.46);
        cursor: not-allowed;
      }

      .file {
        width: 100%;
        min-height: 42px;
        padding: 9px;
        border: 1px solid var(--line);
        border-radius: 6px;
        color: var(--muted);
        background: rgba(255, 255, 255, 0.06);
      }

      .input {
        width: 100%;
        min-height: 40px;
        padding: 8px 10px;
        border: 1px solid var(--line);
        border-radius: 6px;
        color: var(--ink);
        background: rgba(255, 255, 255, 0.06);
      }

      .input::placeholder {
        color: rgba(170, 192, 188, 0.66);
      }

      .slider-row {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 10px;
        align-items: center;
      }

      .slider-row span {
        color: var(--ink);
        font-size: 0.82rem;
        font-weight: 800;
      }

      input[type="range"] {
        width: 100%;
        accent-color: var(--aqua);
      }

      .status-note {
        min-height: 20px;
        color: var(--muted);
        font-size: 0.84rem;
      }

      .timeline {
        height: 8px;
        overflow: hidden;
        border: 1px solid var(--line);
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.08);
      }

      .timeline span {
        display: block;
        width: 0%;
        height: 100%;
        background: linear-gradient(90deg, var(--aqua), var(--gold), var(--rose));
      }

      .contract {
        display: grid;
        gap: 8px;
        margin-top: 12px;
        padding: 0;
        list-style: none;
      }

      .contract li {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        padding-bottom: 8px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        color: var(--muted);
        font-size: 0.9rem;
      }

      .contract strong {
        color: var(--ink);
        font-weight: 750;
      }

      @media (max-width: 920px) {
        .stage,
        .stage-ui {
          min-height: 100vh;
        }
      }
    </style>
  </head>
  <body>
    <div class="app">
      <button class="icon-button menu-toggle" id="drawer-open" type="button" aria-label="Open setup menu">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M4 7h16M4 12h16M4 17h16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
        </svg>
      </button>
      <div class="drawer-backdrop" id="drawer-backdrop" aria-hidden="true"></div>
      <main>
        <aside>
          <div class="drawer-head">
            <div class="drawer-title">
              <div class="mark" aria-hidden="true"></div>
              <div>
                <h1>Music Flow</h1>
                <p class="subhead">Setup</p>
              </div>
            </div>
            <button class="icon-button" id="drawer-close" type="button" aria-label="Close setup menu">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="m6 6 12 12M18 6 6 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
              </svg>
            </button>
          </div>

          <details class="panel" open>
            <summary>Tracks</summary>
            <div class="panel-body">
              <p>Fetches published `ready_tracks` from SB, with the local sample map as backup.</p>
              <div class="track-list" id="track-list"></div>
            </div>
          </details>

          <details class="panel">
            <summary>SB Catalog</summary>
            <div class="panel-body">
              <p>Paste the public anon key once. It is saved only in this browser.</p>
              <div class="controls">
                <label>
                  Project URL
                  <input class="input" id="sb-url" type="url" value="https://veanlffmjvmuqbugsipm.supabase.co">
                </label>
                <label>
                  Anon key
                  <input class="input" id="sb-key" type="password" placeholder="eyJhbGciOi...">
                </label>
                <button class="button primary" id="load-sb" type="button">Load Ready Tracks</button>
                <p class="status-note" id="catalog-status">Waiting for catalog.</p>
              </div>
            </div>
          </details>

          <details class="panel">
            <summary>Sound</summary>
            <div class="panel-body">
              <div class="controls">
                <label>
                  Track volume
                  <div class="slider-row">
                    <input id="music-volume" type="range" min="0" max="100" value="85">
                    <span id="music-volume-value">85%</span>
                  </div>
                </label>
                <label>
                  Tap sounds
                  <div class="slider-row">
                <input id="tap-volume" type="range" min="0" max="100" value="90">
                <span id="tap-volume-value">90%</span>
                  </div>
                </label>
              </div>
            </div>
          </details>

          <details class="panel">
            <summary>Local Playback Test</summary>
            <div class="panel-body">
              <p>Choose any local `.mp3` or `.wav` to test synchronized browser playback. The file stays on this device.</p>
              <div class="controls">
                <input class="file" id="audio-file" type="file" accept="audio/mpeg,audio/wav,audio/mp3,.mp3,.wav">
              </div>
            </div>
          </details>

          <details class="panel">
            <summary>Admin Upload</summary>
            <div class="panel-body">
              <p>Fast MVP upload writes directly to SB Storage and triggers the deployed processing function.</p>
              <div class="controls">
                <label>
                  Title
                  <input class="input" id="upload-title" type="text" placeholder="Calm study">
                </label>
                <label>
                  Artist
                  <input class="input" id="upload-artist" type="text" placeholder="Optional">
                </label>
                <label>
                  Audio file
                  <input class="file" id="upload-file" type="file" accept="audio/mpeg,audio/wav,audio/mp3,.mp3,.wav">
                </label>
                <button class="button primary" id="upload-process" type="button">Upload and Process</button>
                <p class="status-note" id="admin-status">Waiting for audio.</p>
              </div>
            </div>
          </details>

          <details class="panel">
            <summary>Contract</summary>
            <div class="panel-body">
              <ul class="contract">
                <li><span>Storage</span><strong>music-assets</strong></li>
                <li><span>Table</span><strong>tracks</strong></li>
                <li><span>Status</span><strong id="status">loading</strong></li>
                <li><span>Source</span><strong id="source">sample</strong></li>
                <li><span>Events</span><strong id="event-count">0</strong></li>
              </ul>
            </div>
          </details>
        </aside>

        <section class="stage" aria-label="Music reactive visualizer">
          <canvas id="visualizer"></canvas>
          <div class="stage-ui">
            <div class="player-bar" aria-label="Playback controls">
              <button class="button primary play-toggle" id="play-toggle" type="button" disabled>Play</button>
              <div class="track-now">
                <strong id="now-title">No track loaded</strong>
                <span id="now-meta">0 ms</span>
                <div class="timeline" aria-hidden="true"><span id="progress"></span></div>
              </div>
            </div>
          </div>
        </section>
      </main>
    </div>

    <audio id="audio"></audio>

    <script>
      const state = {
        map: { theme: "loading", bpm: 72, duration_ms: 64000, events: [] },
        tracks: [],
        selectedTrackId: "sample",
        nodes: [],
        pulses: [],
        touches: [],
        tileFlashes: [],
        nextEventIndex: 0,
        startedAt: 0,
        pausedAt: 0,
        isPlaying: false,
        lastAction: "idle",
        musicVolume: 0.85,
        tapVolume: 0.9,
        hue: { r: 102, g: 216, b: 203 }
      };

      const canvas = document.getElementById("visualizer");
      const ctx = canvas.getContext("2d");
      const audio = document.getElementById("audio");
      const audioFile = document.getElementById("audio-file");
      const playToggleButton = document.getElementById("play-toggle");
      const progress = document.getElementById("progress");
      const nowTitle = document.getElementById("now-title");
      const nowMeta = document.getElementById("now-meta");
      const statusLabel = document.getElementById("status");
      const sourceLabel = document.getElementById("source");
      const eventCountLabel = document.getElementById("event-count");
      const trackList = document.getElementById("track-list");
      const catalogStatus = document.getElementById("catalog-status");
      const sbUrlInput = document.getElementById("sb-url");
      const sbKeyInput = document.getElementById("sb-key");
      const loadSbButton = document.getElementById("load-sb");
      const uploadTitleInput = document.getElementById("upload-title");
      const uploadArtistInput = document.getElementById("upload-artist");
      const uploadFileInput = document.getElementById("upload-file");
      const uploadProcessButton = document.getElementById("upload-process");
      const adminStatus = document.getElementById("admin-status");
      const drawerOpenButton = document.getElementById("drawer-open");
      const drawerCloseButton = document.getElementById("drawer-close");
      const drawerBackdrop = document.getElementById("drawer-backdrop");
      const musicVolumeInput = document.getElementById("music-volume");
      const tapVolumeInput = document.getElementById("tap-volume");
      const musicVolumeValue = document.getElementById("music-volume-value");
      const tapVolumeValue = document.getElementById("tap-volume-value");

      const storage = {
        url: "music-flow-sb-url",
        key: "music-flow-sb-anon-key",
        musicVolume: "music-flow-music-volume",
        tapVolume: "music-flow-tap-volume"
      };
      const bucketName = "music-assets";
      const grid = {
        cols: 4,
        rows: 6,
        topMargin: 0.09,
        bottomMargin: 0.22
      };
      const synth = {
        context: null,
        master: null,
        scale: [0, 2, 4, 7, 9],
        root: 261.63
      };

      function resize() {
        const ratio = window.devicePixelRatio || 1;
        canvas.width = Math.floor(canvas.clientWidth * ratio);
        canvas.height = Math.floor(canvas.clientHeight * ratio);
        ctx.setTransform(ratio, 0, 0, ratio, 0, 0);
      }

      function loadSoundSettings() {
        state.musicVolume = readStoredVolume(storage.musicVolume, 0.85);
        state.tapVolume = readStoredVolume(storage.tapVolume, 0.9);
        musicVolumeInput.value = String(Math.round(state.musicVolume * 100));
        tapVolumeInput.value = String(Math.round(state.tapVolume * 100));
        applySoundSettings();
      }

      function readStoredVolume(key, fallback) {
        const stored = Number(localStorage.getItem(key));
        if (!Number.isFinite(stored)) return fallback;
        return Math.max(0, Math.min(1, stored));
      }

      function applySoundSettings() {
        audio.volume = state.musicVolume;
        musicVolumeValue.textContent = `${Math.round(state.musicVolume * 100)}%`;
        tapVolumeValue.textContent = `${Math.round(state.tapVolume * 100)}%`;
        if (synth.master) {
          synth.master.gain.setTargetAtTime(0.55 * state.tapVolume, synth.context.currentTime, 0.03);
        }
        localStorage.setItem(storage.musicVolume, String(state.musicVolume));
        localStorage.setItem(storage.tapVolume, String(state.tapVolume));
      }

      function playbackMs(now) {
        if (audio.duration > 0) {
          return Math.floor(audio.currentTime * 1000);
        }

        if (state.isPlaying) {
          return Math.floor(state.pausedAt + now - state.startedAt);
        }

        return Math.floor(state.pausedAt);
      }

      function resetTimeline() {
        state.nodes = [];
        state.pulses = [];
        state.touches = [];
        state.tileFlashes = [];
        state.nextEventIndex = 0;
        state.pausedAt = 0;
        state.startedAt = performance.now();
        state.lastAction = "idle";
        progress.style.width = "0%";
      }

      function selectTrack(track) {
        const map = normalizeLevelMap(track.level_map || fallbackMap());
        state.selectedTrackId = track.id;
        state.map = map;
        state.hue = { r: 102, g: 216, b: 203 };
        resetTimeline();

        if (track.audio_url) {
          audio.src = track.audio_url;
          playToggleButton.disabled = false;
        } else {
          audio.removeAttribute("src");
          audio.load();
          playToggleButton.disabled = true;
        }
        playToggleButton.textContent = "Play";

        statusLabel.textContent = track.processing_status || "ready";
        sourceLabel.textContent = track.source || "sb";
        eventCountLabel.textContent = String(state.map.events.length);
        nowTitle.textContent = track.title || "Untitled Track";
        nowMeta.textContent = `${state.map.bpm} BPM - ${state.map.theme}`;
        renderTrackList();
      }

      function normalizeLevelMap(map) {
        const normalized = {
          schema_version: map.schema_version || 1,
          theme: map.theme || "aurora_ripple",
          bpm: Number(map.bpm || 72),
          duration_ms: Number(map.duration_ms || 64000),
          events: Array.isArray(map.events) ? [...map.events] : []
        };
        normalized.events.sort((a, b) => Number(a.time_ms || 0) - Number(b.time_ms || 0));
        return normalized;
      }

      function renderTrackList() {
        trackList.innerHTML = "";
        for (const track of state.tracks) {
          const button = document.createElement("button");
          button.className = "track";
          button.type = "button";
          button.setAttribute("aria-selected", String(track.id === state.selectedTrackId));
          button.innerHTML = `
            <strong>${escapeHtml(track.title || "Untitled Track")}</strong>
            <span>${escapeHtml(track.artist || track.source || "SB")} - ${track.bpm || 72} BPM - ${escapeHtml((track.level_map && track.level_map.theme) || "aurora_ripple")}</span>
          `;
          button.addEventListener("click", () => selectTrack(track));
          trackList.appendChild(button);
        }
      }

      function escapeHtml(value) {
        return String(value).replace(/[&<>"']/g, (char) => ({
          "&": "&amp;",
          "<": "&lt;",
          ">": "&gt;",
          "\"": "&quot;",
          "'": "&#039;"
        }[char]));
      }

      function handleEvent(event) {
        state.lastAction = event.action;

        if (event.action === "spawn_node") {
          state.nodes.push({
            lane: Number(event.lane || 0),
            born: event.time_ms,
            intensity: Number(event.intensity || 0.5),
            color: event.color || "#66d8cb"
          });
        }

        if (event.action === "pulse_field") {
          state.pulses.push({
            born: event.time_ms,
            x: 0.5,
            y: 0.48,
            intensity: Number(event.intensity || 0.5),
            color: event.color || "#edcb7e"
          });
        }

        if (event.action === "shift_visual_state" && event.target_color) {
          const parsed = parseColor(event.target_color);
          if (parsed) {
            state.hue = parsed;
          }
        }
      }

      function parseColor(hex) {
        const match = /^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i.exec(hex);
        if (!match) return null;
        return {
          r: parseInt(match[1], 16),
          g: parseInt(match[2], 16),
          b: parseInt(match[3], 16)
        };
      }

      function draw(now) {
        const width = canvas.clientWidth;
        const height = canvas.clientHeight;
        const ms = playbackMs(now);
        const duration = audio.duration > 0 ? audio.duration * 1000 : state.map.duration_ms;

        while (
          state.nextEventIndex < state.map.events.length &&
          state.map.events[state.nextEventIndex].time_ms <= ms
        ) {
          handleEvent(state.map.events[state.nextEventIndex]);
          state.nextEventIndex += 1;
        }

        ctx.clearRect(0, 0, width, height);
        const gradient = ctx.createLinearGradient(0, 0, width, height);
        gradient.addColorStop(0, `rgba(${state.hue.r}, ${state.hue.g}, ${state.hue.b}, 0.26)`);
        gradient.addColorStop(0.55, "rgba(11, 22, 27, 0.96)");
        gradient.addColorStop(1, "rgba(23, 18, 37, 0.94)");
        ctx.fillStyle = gradient;
        ctx.fillRect(0, 0, width, height);

        drawRegionGrid(width, height, now);
        drawPulses(width, height, ms);
        drawTouches(width, height, now);
        drawTimingBar(width, height);
        drawNodes(width, height, ms);

        nowMeta.textContent = `${formatTime(ms)} / ${formatTime(duration)} - ${state.map.bpm} BPM`;
        progress.style.width = `${Math.min(100, (ms / duration) * 100)}%`;

        if (state.isPlaying && ms >= duration) {
          state.isPlaying = false;
          state.pausedAt = 0;
          if (!audio.paused) audio.pause();
          audio.currentTime = 0;
          resetTimeline();
          playToggleButton.textContent = "Play";
        }

        requestAnimationFrame(draw);
      }

      function drawTimingBar(width, height) {
        const bounds = getGridBounds(width, height);
        ctx.lineWidth = 1;
        ctx.fillStyle = "rgba(237, 203, 126, 0.22)";
        ctx.fillRect(bounds.left + bounds.tileWidth, bounds.bottom - 8, bounds.tileWidth * 2, 3);
      }

      function drawRegionGrid(width, height, now) {
        const bounds = getGridBounds(width, height);
        ctx.lineWidth = 1;

        for (let col = 0; col <= grid.cols; col += 1) {
          const x = bounds.left + col * bounds.tileWidth;
          ctx.beginPath();
          ctx.moveTo(x, bounds.top);
          ctx.lineTo(x, bounds.bottom);
          ctx.strokeStyle = "rgba(255, 255, 255, 0.075)";
          ctx.stroke();
        }

        for (let row = 0; row <= grid.rows; row += 1) {
          const y = bounds.top + row * bounds.tileHeight;
          ctx.beginPath();
          ctx.moveTo(bounds.left, y);
          ctx.lineTo(bounds.right, y);
          ctx.strokeStyle = "rgba(255, 255, 255, 0.045)";
          ctx.stroke();
        }

        state.tileFlashes = state.tileFlashes.filter((flash) => now - flash.born < 850);
        for (const flash of state.tileFlashes) {
          const age = now - flash.born;
          const t = age / 850;
          const x = bounds.left + flash.col * bounds.tileWidth;
          const y = bounds.top + flash.row * bounds.tileHeight;
          ctx.fillStyle = flash.color;
          ctx.globalAlpha = (1 - t) * 0.2;
          ctx.fillRect(x, y, bounds.tileWidth, bounds.tileHeight);
          ctx.globalAlpha = 1;
        }
      }

      function drawNodes(width, height, ms) {
        const laneCount = 4;
        const laneWidth = Math.min(90, width / 7);
        const start = width / 2 - (laneWidth * laneCount) / 2;
        const travelMs = 2800;

        state.nodes = state.nodes.filter((node) => ms - node.born < travelMs + 500);
        for (const node of state.nodes) {
          const age = ms - node.born;
          const t = Math.max(0, Math.min(1, age / travelMs));
          const x = start + (Math.max(0, Math.min(laneCount - 1, node.lane)) + 0.5) * laneWidth;
          const y = height * 0.16 + t * (height * 0.7);
          const radius = 10 + node.intensity * 11;

          ctx.beginPath();
          ctx.arc(x, y, radius, 0, Math.PI * 2);
          ctx.fillStyle = node.color;
          ctx.globalAlpha = 0.78;
          ctx.fill();
          ctx.globalAlpha = 1;

          ctx.beginPath();
          ctx.arc(x, y, radius + 8, 0, Math.PI * 2);
          ctx.strokeStyle = "rgba(255, 255, 255, 0.28)";
          ctx.stroke();
        }
      }

      function drawPulses(width, height, ms) {
        state.pulses = state.pulses.filter((pulse) => ms - pulse.born < 1800);
        for (const pulse of state.pulses) {
          const age = ms - pulse.born;
          const t = age / 1800;
          ctx.beginPath();
          ctx.arc((pulse.x || 0.5) * width, (pulse.y || 0.48) * height, 80 + t * Math.max(width, height) * 0.42, 0, Math.PI * 2);
          ctx.strokeStyle = pulse.color;
          ctx.globalAlpha = (1 - t) * 0.28 * pulse.intensity;
          ctx.lineWidth = 3;
          ctx.stroke();
          ctx.globalAlpha = 1;
        }
      }

      function drawTouches(width, height, now) {
        state.touches = state.touches.filter((touch) => now - touch.born < 1300);
        for (const touch of state.touches) {
          const age = now - touch.born;
          const t = age / 1300;
          const x = touch.x * width;
          const y = touch.y * height;

          ctx.beginPath();
          ctx.arc(x, y, 18 + t * 90, 0, Math.PI * 2);
          ctx.strokeStyle = touch.color;
          ctx.globalAlpha = (1 - t) * 0.46;
          ctx.lineWidth = 2;
          ctx.stroke();

          ctx.beginPath();
          ctx.arc(x, y, 5 + (1 - t) * 8, 0, Math.PI * 2);
          ctx.fillStyle = touch.color;
          ctx.globalAlpha = (1 - t) * 0.72;
          ctx.fill();
          ctx.globalAlpha = 1;
        }
      }

      function interactWithStage(event, shouldPlayTone = true) {
        const rect = canvas.getBoundingClientRect();
        const x = Math.max(0, Math.min(1, (event.clientX - rect.left) / rect.width));
        const y = Math.max(0, Math.min(1, (event.clientY - rect.top) / rect.height));
        const now = performance.now();
        const ms = playbackMs(now);
        const color = y > 0.65 ? "#edcb7e" : "#66d8cb";
        const tile = getTileAt(x, y);

        state.touches.push({ x, y, born: now, color });
        state.pulses.push({
          born: ms,
          x,
          y,
          intensity: 0.34,
          color
        });

        if (tile && shouldPlayTone) {
          state.tileFlashes.push({ ...tile, born: now, color });
          playTileTone(tile);
        }

        collectNearbyNode(x, y, ms);
        state.lastAction = "touch_ripple";
      }

      function getGridBounds(width, height) {
        const top = height * grid.topMargin;
        const bottom = height * (1 - grid.bottomMargin);
        return {
          left: 0,
          right: width,
          top,
          bottom,
          tileWidth: width / grid.cols,
          tileHeight: (bottom - top) / grid.rows
        };
      }

      function getTileAt(x, y) {
        if (y < grid.topMargin || y > 1 - grid.bottomMargin) return null;
        const localY = (y - grid.topMargin) / (1 - grid.topMargin - grid.bottomMargin);
        const col = Math.max(0, Math.min(grid.cols - 1, Math.floor(x * grid.cols)));
        const row = Math.max(0, Math.min(grid.rows - 1, Math.floor(localY * grid.rows)));
        return { col, row, index: row * grid.cols + col };
      }

      function ensureSynth() {
        if (synth.context) return synth.context;
        const AudioContextClass = window.AudioContext || window.webkitAudioContext;
        if (!AudioContextClass) return null;

        const context = new AudioContextClass();
        const master = context.createGain();

        master.gain.value = 0.55 * state.tapVolume;
        master.connect(context.destination);

        synth.context = context;
        synth.master = master;
        return context;
      }

      function playTileTone(tile) {
        const context = ensureSynth();
        if (!context) return;
        if (context.state === "suspended") {
          context.resume();
        }

        const now = context.currentTime;
        const frequency = tileToFrequency(tile);
        const voice = context.createOscillator();
        const shimmer = context.createOscillator();
        const gain = context.createGain();
        const filter = context.createBiquadFilter();
        const shimmerGain = context.createGain();

        voice.type = "sine";
        voice.frequency.setValueAtTime(frequency, now);
        shimmer.type = "triangle";
        shimmer.frequency.setValueAtTime(frequency * 2, now);

        filter.type = "lowpass";
        filter.frequency.setValueAtTime(900 + tile.col * 260 + (grid.rows - tile.row) * 70, now);
        filter.Q.value = 0.6;

        gain.gain.setValueAtTime(0.0001, now);
        gain.gain.exponentialRampToValueAtTime(0.18, now + 0.035);
        gain.gain.exponentialRampToValueAtTime(0.0001, now + 1.6);

        shimmerGain.gain.setValueAtTime(0.0001, now);
        shimmerGain.gain.exponentialRampToValueAtTime(0.035, now + 0.055);
        shimmerGain.gain.exponentialRampToValueAtTime(0.0001, now + 1.2);

        voice.connect(filter);
        filter.connect(gain);
        shimmer.connect(shimmerGain);
        shimmerGain.connect(gain);
        gain.connect(synth.master);

        voice.start(now);
        shimmer.start(now);
        voice.stop(now + 1.7);
        shimmer.stop(now + 1.25);
      }

      function tileToFrequency(tile) {
        const invertedRow = grid.rows - 1 - tile.row;
        const scaleIndex = tile.col + invertedRow * 2;
        const octave = Math.floor(scaleIndex / synth.scale.length);
        const semitone = synth.scale[scaleIndex % synth.scale.length] + octave * 12;
        return synth.root * Math.pow(2, semitone / 12);
      }

      function collectNearbyNode(x, y, ms) {
        const width = canvas.clientWidth;
        const height = canvas.clientHeight;
        const laneCount = 4;
        const laneWidth = Math.min(90, width / 7);
        const start = width / 2 - (laneWidth * laneCount) / 2;
        const travelMs = 2800;
        const pointerX = x * width;
        const pointerY = y * height;
        let collected = false;

        state.nodes = state.nodes.filter((node) => {
          const age = ms - node.born;
          const t = Math.max(0, Math.min(1, age / travelMs));
          const nodeX = start + (Math.max(0, Math.min(laneCount - 1, node.lane)) + 0.5) * laneWidth;
          const nodeY = height * 0.16 + t * (height * 0.7);
          const distance = Math.hypot(pointerX - nodeX, pointerY - nodeY);
          const keep = distance > 54;
          collected = collected || !keep;
          return keep;
        });

        if (collected) {
          state.lastAction = "collect_node";
          state.pulses.push({
            born: ms,
            x,
            y,
            intensity: 0.72,
            color: "#edcb7e"
          });
        }
      }

      function formatTime(ms) {
        if (!Number.isFinite(ms)) return "0:00";
        const totalSeconds = Math.max(0, Math.floor(ms / 1000));
        const minutes = Math.floor(totalSeconds / 60);
        const seconds = String(totalSeconds % 60).padStart(2, "0");
        return `${minutes}:${seconds}`;
      }

      async function loadMap() {
        loadSavedSbConfig();

        if (sbKeyInput.value.trim()) {
          try {
            await loadSupabaseTracks();
            return;
          } catch (error) {
            catalogStatus.textContent = `SB fetch failed. Using sample map.`;
          }
        }

        try {
          const response = await fetch("data/sample-level-map.json");
          const sampleMap = normalizeLevelMap(await response.json());
          state.tracks = [{
            id: "sample",
            title: "Aurora Timing Study",
            artist: "Local sample",
            bpm: sampleMap.bpm,
            level_map: sampleMap,
            processing_status: "ready",
            source: "sample"
          }];
          selectTrack(state.tracks[0]);
          catalogStatus.textContent = "Loaded local sample map.";
        } catch (error) {
          statusLabel.textContent = "offline";
          const map = fallbackMap();
          state.tracks = [{
            id: "fallback",
            title: "Fallback Timing Study",
            artist: "Generated fallback",
            bpm: map.bpm,
            level_map: map,
            processing_status: "offline",
            source: "fallback"
          }];
          selectTrack(state.tracks[0]);
          catalogStatus.textContent = "Using generated fallback map.";
        }
      }

      function loadSavedSbConfig() {
        sbUrlInput.value = localStorage.getItem(storage.url) || sbUrlInput.value;
        sbKeyInput.value = localStorage.getItem(storage.key) || "";
      }

      function saveSbConfig() {
        localStorage.setItem(storage.url, sbUrlInput.value.trim());
        localStorage.setItem(storage.key, sbKeyInput.value.trim());
      }

      function getSbConfig() {
        const baseUrl = sbUrlInput.value.trim().replace(/\/$/, "");
        const anonKey = sbKeyInput.value.trim();
        if (!baseUrl || !anonKey) {
          throw new Error("Add the SB URL and anon key first.");
        }
        saveSbConfig();
        return { baseUrl, anonKey };
      }

      async function loadSupabaseTracks() {
        const { baseUrl, anonKey } = getSbConfig();
        const endpoint = `${baseUrl}/rest/v1/ready_tracks?select=id,title,artist,audio_url,bpm,duration_ms,level_map,created_at&order=created_at.desc`;

        catalogStatus.textContent = "Loading SB ready_tracks...";
        const response = await fetch(endpoint, {
          headers: {
            apikey: anonKey,
            Authorization: `Bearer ${anonKey}`
          }
        });

        if (!response.ok) {
          throw new Error(`SB returned ${response.status}`);
        }

        const rows = await response.json();
        if (!Array.isArray(rows) || rows.length === 0) {
          throw new Error("No ready tracks found");
        }

        state.tracks = rows.map((row) => ({
          ...row,
          bpm: row.bpm || (row.level_map && row.level_map.bpm) || 72,
          processing_status: "ready",
          source: "sb"
        }));
        selectTrack(state.tracks[0]);
        catalogStatus.textContent = `Loaded ${state.tracks.length} ready track${state.tracks.length === 1 ? "" : "s"} from SB.`;
      }

      async function uploadAndProcessTrack() {
        const { baseUrl, anonKey } = getSbConfig();
        const file = uploadFileInput.files && uploadFileInput.files[0];
        const title = uploadTitleInput.value.trim() || (file && file.name.replace(/\.[^.]+$/, "")) || "Untitled Track";
        const artist = uploadArtistInput.value.trim();

        if (!file) {
          throw new Error("Choose an audio file first.");
        }

        const extension = file.name.includes(".") ? file.name.split(".").pop().toLowerCase() : "mp3";
        const storagePath = `uploads/${Date.now()}-${slugify(title)}.${extension}`;
        const encodedPath = storagePath.split("/").map(encodeURIComponent).join("/");
        const storageUrl = `${baseUrl}/storage/v1/object/${bucketName}/${encodedPath}`;
        const publicAudioUrl = `${baseUrl}/storage/v1/object/public/${bucketName}/${encodedPath}`;

        adminStatus.textContent = "Analyzing local audio timing...";
        const analysis = await analyzeAudioFile(file);

        adminStatus.textContent = "Uploading audio to SB Storage...";
        const uploadResponse = await fetch(storageUrl, {
          method: "POST",
          headers: {
            apikey: anonKey,
            Authorization: `Bearer ${anonKey}`,
            "Content-Type": file.type || "application/octet-stream",
            "x-upsert": "true"
          },
          body: file
        });

        if (!uploadResponse.ok) {
          throw new Error(`Storage upload failed with ${uploadResponse.status}`);
        }

        adminStatus.textContent = "Creating track row...";
        const insertResponse = await fetch(`${baseUrl}/rest/v1/tracks`, {
          method: "POST",
          headers: {
            apikey: anonKey,
            Authorization: `Bearer ${anonKey}`,
            "Content-Type": "application/json",
            Prefer: "return=representation"
          },
          body: JSON.stringify({
            title,
            artist: artist || null,
            storage_path: storagePath,
            audio_url: publicAudioUrl,
            bpm: analysis.bpm,
            duration_ms: analysis.duration_ms,
            processing_status: "uploaded",
            is_published: false
          })
        });

        if (!insertResponse.ok) {
          throw new Error(`Track insert failed with ${insertResponse.status}`);
        }

        const rows = await insertResponse.json();
        const track = rows && rows[0];
        if (!track || !track.id) {
          throw new Error("Track insert did not return an id.");
        }

        adminStatus.textContent = "Processing level map...";
        const processResponse = await fetch(`${baseUrl}/functions/v1/process-track`, {
          method: "POST",
          headers: {
            apikey: anonKey,
            Authorization: `Bearer ${anonKey}`,
            "Content-Type": "application/json"
          },
          body: JSON.stringify({ track_id: track.id, storage_path: storagePath, analysis })
        });

        if (!processResponse.ok) {
          const errorBody = await processResponse.text();
          throw new Error(`Processing failed with ${processResponse.status}: ${errorBody}`);
        }

        adminStatus.textContent = "Track ready. Refreshing catalog...";
        await loadSupabaseTracks();
        const readyTrack = state.tracks.find((item) => item.id === track.id);
        if (readyTrack) {
          selectTrack(readyTrack);
        }
        adminStatus.textContent = `"${title}" is ready.`;
      }

      function slugify(value) {
        return value
          .toLowerCase()
          .replace(/[^a-z0-9]+/g, "-")
          .replace(/^-+|-+$/g, "")
          .slice(0, 48) || "track";
      }

      async function analyzeAudioFile(file) {
        const AudioContextClass = window.AudioContext || window.webkitAudioContext;
        if (!AudioContextClass) {
          return { bpm: 72, duration_ms: 64000, onsets: [] };
        }

        const arrayBuffer = await file.arrayBuffer();
        const audioContext = new AudioContextClass();
        try {
          const audioBuffer = await audioContext.decodeAudioData(arrayBuffer.slice(0));
          const channelData = audioBuffer.getChannelData(0);
          const sampleRate = audioBuffer.sampleRate;
          const frameSize = 2048;
          const hopSize = 1024;
          const envelope = [];

          for (let start = 0; start < channelData.length - frameSize; start += hopSize) {
            let sum = 0;
            for (let index = 0; index < frameSize; index += 1) {
              const sample = channelData[start + index];
              sum += sample * sample;
            }
            envelope.push(Math.sqrt(sum / frameSize));
          }

          const smoothed = smoothEnvelope(envelope, 4);
          const flux = [];
          for (let index = 1; index < smoothed.length; index += 1) {
            flux.push(Math.max(0, smoothed[index] - smoothed[index - 1]));
          }

          const durationMs = Math.round(audioBuffer.duration * 1000);
          const bpm = estimateBpm(flux, sampleRate, hopSize);
          const onsets = pickOnsets(flux, sampleRate, hopSize, durationMs);
          return { bpm, duration_ms: durationMs, onsets };
        } finally {
          if (audioContext.close) {
            audioContext.close();
          }
        }
      }

      function smoothEnvelope(values, radius) {
        return values.map((_, index) => {
          let sum = 0;
          let count = 0;
          for (let offset = -radius; offset <= radius; offset += 1) {
            const value = values[index + offset];
            if (value === undefined) continue;
            sum += value;
            count += 1;
          }
          return count > 0 ? sum / count : 0;
        });
      }

      function estimateBpm(flux, sampleRate, hopSize) {
        if (flux.length < 16) return 72;
        const frameMs = (hopSize / sampleRate) * 1000;
        let bestBpm = 72;
        let bestScore = -Infinity;

        for (let bpm = 50; bpm <= 150; bpm += 1) {
          const lag = Math.round((60000 / bpm) / frameMs);
          if (lag < 2 || lag >= flux.length) continue;
          let score = 0;
          for (let index = lag; index < flux.length; index += 1) {
            score += flux[index] * flux[index - lag];
          }
          if (score > bestScore) {
            bestScore = score;
            bestBpm = bpm;
          }
        }

        return bestBpm;
      }

      function pickOnsets(flux, sampleRate, hopSize, durationMs) {
        if (flux.length === 0) return [];
        const sorted = [...flux].sort((a, b) => a - b);
        const threshold = sorted[Math.floor(sorted.length * 0.82)] || 0;
        const maxFlux = sorted[sorted.length - 1] || 1;
        const frameMs = (hopSize / sampleRate) * 1000;
        const onsets = [];
        let lastMs = -600;

        for (let index = 1; index < flux.length - 1; index += 1) {
          const value = flux[index];
          const timeMs = Math.round(index * frameMs);
          const isPeak = value > threshold && value >= flux[index - 1] && value >= flux[index + 1];
          if (!isPeak || timeMs - lastMs < 420 || timeMs > durationMs - 250) continue;

          onsets.push({
            time_ms: timeMs,
            intensity: Math.max(0.2, Math.min(1, value / maxFlux))
          });
          lastMs = timeMs;

          if (onsets.length >= 180) break;
        }

        return onsets;
      }

      function fallbackMap() {
        return {
          theme: "aurora_ripple",
          bpm: 72,
          duration_ms: 32000,
          events: Array.from({ length: 24 }, (_, index) => ({
            time_ms: 900 + index * 1100,
            action: index % 5 === 0 ? "pulse_field" : "spawn_node",
            lane: index % 4,
            intensity: 0.45 + (index % 3) * 0.18,
            color: index % 2 === 0 ? "#66d8cb" : "#edcb7e"
          }))
        };
      }

      audioFile.addEventListener("change", () => {
        const file = audioFile.files && audioFile.files[0];
        if (!file) return;
        audio.src = URL.createObjectURL(file);
        playToggleButton.disabled = false;
        nowTitle.textContent = file.name;
        resetTimeline();
      });

      loadSbButton.addEventListener("click", async () => {
        try {
          await loadSupabaseTracks();
        } catch (error) {
          catalogStatus.textContent = error instanceof Error ? error.message : "Unable to load SB catalog.";
        }
      });

      uploadProcessButton.addEventListener("click", async () => {
        uploadProcessButton.disabled = true;
        try {
          await uploadAndProcessTrack();
        } catch (error) {
          adminStatus.textContent = error instanceof Error ? error.message : "Upload/process failed.";
        } finally {
          uploadProcessButton.disabled = false;
        }
      });

      musicVolumeInput.addEventListener("input", () => {
        state.musicVolume = Number(musicVolumeInput.value) / 100;
        applySoundSettings();
      });

      tapVolumeInput.addEventListener("input", () => {
        state.tapVolume = Number(tapVolumeInput.value) / 100;
        applySoundSettings();
      });

      playToggleButton.addEventListener("click", async () => {
        if (state.isPlaying) {
          state.pausedAt = playbackMs(performance.now());
          state.isPlaying = false;
          audio.pause();
          playToggleButton.textContent = "Play";
          return;
        }

        state.isPlaying = true;
        state.startedAt = performance.now();
        playToggleButton.textContent = "Pause";
        if (audio.src) {
          await audio.play();
        }
      });

      canvas.addEventListener("pointerdown", (event) => {
        canvas.setPointerCapture(event.pointerId);
        interactWithStage(event, true);
      });

      canvas.addEventListener("pointermove", (event) => {
        if (event.buttons !== 1 && event.pointerType !== "touch") return;
        interactWithStage(event, false);
      });

      window.addEventListener("resize", resize);
      drawerOpenButton.addEventListener("click", () => {
        document.body.classList.add("drawer-open");
      });
      drawerCloseButton.addEventListener("click", () => {
        document.body.classList.remove("drawer-open");
      });
      drawerBackdrop.addEventListener("click", () => {
        document.body.classList.remove("drawer-open");
      });
      loadSoundSettings();
      resize();
      loadMap().then(() => requestAnimationFrame(draw));
    </script>
  </body>
</html>
</file>

